DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@postgres:5432/<DB_NAME>
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=uploads
LEAD_AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_SERVICE_ENABLED=true
AI_SERVICE_URL=http://ai_openai:8100
AI_SERVICE_TIMEOUT_SECONDS=20
AI_SERVICE_AUTH_TOKEN=
REDIS_URL=redis://redis:6379/0
LEAD_AI_QUEUE_NAME=lead_ai
LEAD_AI_JOB_TIMEOUT=180
LEAD_AI_RETRY_MAX=3
OBS_SAMPLE_INTERVAL_SECONDS=10
OBS_HISTORY_RETENTION_DAYS=30
