generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String           @unique
  name             String
  category         String
  shortDescription String?          @map("short_description")
  description      String?
  material         String?
  minOrderQty      Int              @default(1) @map("min_order_qty")
  leadTimeDays     Int              @default(7) @map("lead_time_days")
  isActive         Boolean          @default(true) @map("is_active")
  createdByUserId  String?          @map("created_by_user_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sizes            String[]         @default([])
  colors           String[]         @default([])
  brandingOptions  String[]         @default([]) @map("branding_options")
  tags             String[]         @default([])
  priceTiers       Json             @default("[]") @map("price_tiers")
  image            String           @default("")
  gallery          String[]         @default([])
  featured         Boolean          @default(false)
  variants         ProductVariant[]
  users            users?           @relation(fields: [createdByUserId], references: [id], onUpdate: NoAction)
  quote_items      quote_items[]

  @@index([category], map: "idx_products_category")
  @@index([isActive], map: "idx_products_is_active")
  @@map("products")
}

model ProductVariant {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String        @map("product_id") @db.Uuid
  sku         String        @unique
  variantName String        @map("variant_name")
  size        String?
  color       String?
  unitPrice   Decimal       @map("unit_price") @db.Decimal(12, 2)
  moq         Int           @default(1)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quote_items quote_items[]

  @@index([isActive], map: "idx_product_variants_is_active")
  @@index([productId], map: "idx_product_variants_product_id")
  @@map("product_variants")
}

model activities {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?    @db.Uuid
  customer_id   String?    @db.Uuid
  lead_id       String?    @db.Uuid
  deal_id       String?    @db.Uuid
  quote_id      String?    @db.Uuid
  activity_type String
  title         String
  details       String?
  metadata      Json       @default("{}")
  occurred_at   DateTime   @default(now()) @db.Timestamptz(6)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @db.Timestamptz(6)
  customers     customers? @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  deals         deals?     @relation(fields: [deal_id], references: [id], onUpdate: NoAction)
  leads         leads?     @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  quotes        quotes?    @relation(fields: [quote_id], references: [id], onUpdate: NoAction)
  users         users?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([activity_type], map: "idx_activities_activity_type")
  @@index([customer_id], map: "idx_activities_customer_id")
  @@index([deal_id], map: "idx_activities_deal_id")
  @@index([lead_id], map: "idx_activities_lead_id")
  @@index([occurred_at(sort: Desc)], map: "idx_activities_occurred_at")
  @@index([quote_id], map: "idx_activities_quote_id")
  @@index([user_id], map: "idx_activities_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model automation_runs {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflow_name       String
  trigger_source      String
  trigger_entity_type String?
  trigger_entity_id   String?   @db.Uuid
  status              String    @default("queued")
  request_payload     Json      @default("{}")
  response_payload    Json      @default("{}")
  error_message       String?
  started_at          DateTime? @db.Timestamptz(6)
  finished_at         DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_automation_runs_created_at")
  @@index([status], map: "idx_automation_runs_status")
  @@index([trigger_entity_type, trigger_entity_id], map: "idx_automation_runs_trigger")
  @@index([workflow_name], map: "idx_automation_runs_workflow_name")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model communications {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String?    @db.Uuid
  lead_id             String?    @db.Uuid
  deal_id             String?    @db.Uuid
  quote_id            String?    @db.Uuid
  user_id             String?    @db.Uuid
  channel             String
  direction           String
  subject             String?
  message_text        String?
  external_message_id String?
  sent_at             DateTime?  @db.Timestamptz(6)
  delivered_at        DateTime?  @db.Timestamptz(6)
  read_at             DateTime?  @db.Timestamptz(6)
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime   @default(now()) @db.Timestamptz(6)
  customers           customers? @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  deals               deals?     @relation(fields: [deal_id], references: [id], onUpdate: NoAction)
  leads               leads?     @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  quotes              quotes?    @relation(fields: [quote_id], references: [id], onUpdate: NoAction)
  users               users?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([channel], map: "idx_communications_channel")
  @@index([created_at(sort: Desc)], map: "idx_communications_created_at")
  @@index([customer_id], map: "idx_communications_customer_id")
  @@index([deal_id], map: "idx_communications_deal_id")
  @@index([direction], map: "idx_communications_direction")
  @@index([lead_id], map: "idx_communications_lead_id")
  @@index([quote_id], map: "idx_communications_quote_id")
}

model customers {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_name     String
  contact_name     String?
  email            String?
  phone            String?
  whatsapp         String?
  billing_address  String?
  shipping_address String?
  industry         String?
  notes            String?
  owner_user_id    String?          @db.Uuid
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @db.Timestamptz(6)
  activities       activities[]
  communications   communications[]
  users            users?           @relation(fields: [owner_user_id], references: [id], onUpdate: NoAction)
  deals            deals[]
  followups        followups[]
  leads            leads[]
  quotes           quotes[]

  @@index([owner_user_id], map: "idx_customers_owner_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model deals {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String?          @db.Uuid
  customer_id         String           @db.Uuid
  owner_user_id       String?          @db.Uuid
  title               String
  stage               String           @default("new")
  expected_value      Decimal          @default(0) @db.Decimal(12, 2)
  probability_pct     Int              @default(0)
  expected_close_date DateTime?        @db.Date
  won_at              DateTime?        @db.Timestamptz(6)
  lost_reason         String?
  notes               String?
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @db.Timestamptz(6)
  activities          activities[]
  communications      communications[]
  customers           customers        @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  leads               leads?           @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  users               users?           @relation(fields: [owner_user_id], references: [id], onUpdate: NoAction)
  followups           followups[]
  quotes              quotes[]

  @@index([customer_id], map: "idx_deals_customer_id")
  @@index([lead_id], map: "idx_deals_lead_id")
  @@index([owner_user_id], map: "idx_deals_owner_user_id")
  @@index([stage], map: "idx_deals_stage")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model followups {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String?    @db.Uuid
  lead_id             String?    @db.Uuid
  deal_id             String?    @db.Uuid
  quote_id            String?    @db.Uuid
  assigned_to_user_id String?    @db.Uuid
  status              String     @default("pending")
  priority            String     @default("medium")
  channel             String?
  subject             String
  notes               String?
  due_at              DateTime   @db.Timestamptz(6)
  completed_at        DateTime?  @db.Timestamptz(6)
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime   @default(now()) @db.Timestamptz(6)
  users               users?     @relation(fields: [assigned_to_user_id], references: [id], onUpdate: NoAction)
  customers           customers? @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  deals               deals?     @relation(fields: [deal_id], references: [id], onUpdate: NoAction)
  leads               leads?     @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
  quotes              quotes?    @relation(fields: [quote_id], references: [id], onUpdate: NoAction)

  @@index([assigned_to_user_id], map: "idx_followups_assigned_to_user_id")
  @@index([customer_id], map: "idx_followups_customer_id")
  @@index([deal_id], map: "idx_followups_deal_id")
  @@index([due_at], map: "idx_followups_due_at")
  @@index([lead_id], map: "idx_followups_lead_id")
  @@index([quote_id], map: "idx_followups_quote_id")
  @@index([status], map: "idx_followups_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model leads {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String?          @db.Uuid
  assigned_to_user_id String?          @db.Uuid
  source              String           @default("website")
  status              String           @default("new")
  lead_score          Int?
  company_name        String?
  contact_name        String
  email               String?
  phone               String?
  requested_qty       Int?
  budget              Decimal?         @db.Decimal(12, 2)
  timeline_date       DateTime?        @db.Date
  notes               String?
  last_contacted_at   DateTime?        @db.Timestamptz(6)
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @default(now()) @db.Timestamptz(6)
  ai_product          String?
  ai_quantity         Int?
  ai_urgency          String?
  ai_complexity       String?
  ai_processed_at     DateTime?        @db.Timestamptz(6)
  ai_provider         String?
  ai_fallback_used    Boolean          @default(false)
  ai_score            Int?
  ai_classification   String?
  ai_reasoning        Json             @default("{}")
  activities          activities[]
  communications      communications[]
  deals               deals[]
  followups           followups[]
  users               users?           @relation(fields: [assigned_to_user_id], references: [id], onUpdate: NoAction)
  customers           customers?       @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  quotes              quotes[]

  @@index([ai_processed_at], map: "idx_leads_ai_processed_at")
  @@index([assigned_to_user_id], map: "idx_leads_assigned_to_user_id")
  @@index([created_at(sort: Desc)], map: "idx_leads_created_at")
  @@index([customer_id], map: "idx_leads_customer_id")
  @@index([source], map: "idx_leads_source")
  @@index([status], map: "idx_leads_status")
