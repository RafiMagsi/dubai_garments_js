/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model quotes {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quote_number       String           @unique
  customer_id        String           @db.Uuid
  lead_id            String?          @db.Uuid
  deal_id            String?          @db.Uuid
  created_by_user_id String?          @db.Uuid
  status             String           @default("draft")
  currency           String           @default("AED")
  subtotal           Decimal          @default(0) @db.Decimal(12, 2)
  tax_amount         Decimal          @default(0) @db.Decimal(12, 2)
  discount_amount    Decimal          @default(0) @db.Decimal(12, 2)
  total_amount       Decimal          @default(0) @db.Decimal(12, 2)
  valid_until        DateTime?        @db.Date
  terms              String?
  notes              String?
  sent_at            DateTime?        @db.Timestamptz(6)
  approved_at        DateTime?        @db.Timestamptz(6)
  rejected_at        DateTime?        @db.Timestamptz(6)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @default(now()) @db.Timestamptz(6)
  activities         activities[]
  communications     communications[]
  followups          followups[]
  quote_items        quote_items[]
  users              users?           @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  customers          customers        @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  deals              deals?           @relation(fields: [deal_id], references: [id], onUpdate: NoAction)
  leads              leads?           @relation(fields: [lead_id], references: [id], onUpdate: NoAction)

  @@index([customer_id], map: "idx_quotes_customer_id")
  @@index([deal_id], map: "idx_quotes_deal_id")
  @@index([lead_id], map: "idx_quotes_lead_id")
  @@index([status], map: "idx_quotes_status")
  @@index([valid_until], map: "idx_quotes_valid_until")
}

model schema_migrations {
  name       String   @id
  applied_at DateTime @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name      String
  email          String           @unique
  password_hash  String
  role           String           @default("sales_rep")
  is_active      Boolean          @default(true)
  last_login_at  DateTime?        @db.Timestamptz(6)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  activities     activities[]
  communications communications[]
  customers      customers[]
  deals          deals[]
  followups      followups[]
  leads          leads[]
  products       Product[]
  quotes         quotes[]
}
