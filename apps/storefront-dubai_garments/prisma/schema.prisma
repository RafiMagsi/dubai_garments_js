generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String   @unique
  name             String
  category         String
  shortDescription String?  @map("short_description")
  description      String?
  material         String?
  minOrderQty      Int      @default(1) @map("min_order_qty")
  leadTimeDays     Int      @default(7) @map("lead_time_days")
  sizes            String[] @default([])
  colors           String[] @default([])
  brandingOptions  String[] @default([]) @map("branding_options")
  tags             String[] @default([])
  priceTiers       Json     @default("[]") @map("price_tiers")
  image            String   @default("")
  gallery          String[] @default([])
  featured         Boolean  @default(false)
  isActive         Boolean  @default(true) @map("is_active")
  createdByUserId  String?  @db.Uuid @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  variants ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String   @db.Uuid @map("product_id")
  sku         String   @unique
  variantName String   @map("variant_name")
  size        String?
  color       String?
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  moq         Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}
