[Unit]
Description=Dubai Garments AI OpenAI Service
After=network.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__PROJECT_ROOT__/services/ai_openai_service
EnvironmentFile=__PROJECT_ROOT__/services/ai_openai_service/.env
ExecStart=__PROJECT_ROOT__/services/ai_openai_service/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8100
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
